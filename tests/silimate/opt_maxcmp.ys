# ---- negatives: must not rewrite (and stay equivalent trivially) ----------

log -header "nomatch_sum: no rewrite"
design -reset
read_verilog -sv opt_maxcmp.sv
hierarchy -top nomatch_sum
proc; opt
opt_maxcmp
select -assert-count 0 c:*_maxcmp_*

