# Tests for opt_maxcmp.
#
# For every design: equiv_opt -assert proves the rewrite is equivalent, and a
# structural check confirms the pass fired (positive) or left the design alone
# (negative). Designs are combinational with packed-vector ports so the
# built-in Verilog frontend works and the miter is a plain combinational check.

# ---- helper macro via a repeated pattern ---------------------------------
# positive: prove equivalence, then confirm a maxcmp region was emitted.

log -header "maxcmp_scatter: equivalence"
design -reset
read_verilog -sv opt_maxcmp.sv
hierarchy -top maxcmp_scatter
proc; opt
equiv_opt -assert opt_maxcmp

log -header "maxcmp_scatter: rewrite fired"
design -reset
read_verilog -sv opt_maxcmp.sv
hierarchy -top maxcmp_scatter
proc; opt
opt_maxcmp
select -assert-min 1 c:*_maxcmp_*

log -header "maxcmp_bcast: equivalence"
design -reset
read_verilog -sv opt_maxcmp.sv
hierarchy -top maxcmp_bcast
proc; opt
equiv_opt -assert opt_maxcmp

log -header "maxcmp_bcast: rewrite fired"
design -reset
read_verilog -sv opt_maxcmp.sv
hierarchy -top maxcmp_bcast
proc; opt
opt_maxcmp
select -assert-min 1 c:*_maxcmp_*

