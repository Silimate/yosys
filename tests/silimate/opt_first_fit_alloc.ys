# ---------------------------------------------------------------------------
log -header "Shared match (track_texel mirror): self-equivalence"
log -push
design -reset
verific -sv opt_first_fit_alloc_match.sv
verific -import opt_first_fit_alloc_match
proc; opt_clean
equiv_opt -assert opt_first_fit_alloc
