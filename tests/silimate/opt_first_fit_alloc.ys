# Tests for opt_first_fit_alloc, focused on the gather-rooted anchor (first-fit
# allocators consumed only as a per-slot data gather, with no explicit dsel
# index), plus a regression check that the original split-root path still fires.
#
# Each positive case has two blocks:
#   * self-equivalence (equiv_opt -assert), which builds a gold/gate miter and
#     discharges it by induction, so it covers the sequential FF-Q feedback, and
#   * "rewrite fired" via logger -expect on the pass's own per-region log line.
# The pass runs `clean -purge` after a successful rewrite (which strips the
# private ffa_* marker nets), so the log line - not a wire-name select - is the
# durable, path-discriminating proof that the intended anchor fired:
#     clean identity gather : "... gather-rooted(en=...)"
#     compacted gather      : "... gather-rooted-compacted(en=...)"
#     original split-root    : "... first_fit_alloc(en=..., exclusive ...)"
# Near-miss negatives assert "Rewrote 0 first-fit alloc region(s)".

# ---------------------------------------------------------------------------
# Clean identity gather (LSB-first, no guard, no compaction)
# ---------------------------------------------------------------------------
log -header "Basic identity gather: self-equivalence"
log -push
design -reset
verific -sv opt_first_fit_alloc_basic.sv
verific -import opt_first_fit_alloc_basic
proc; opt_clean
equiv_opt -assert opt_first_fit_alloc
design -reset
log -pop

log -header "Basic identity gather: rewrite fired (clean gather-root path)"
log -push
design -reset
verific -sv opt_first_fit_alloc_basic.sv
verific -import opt_first_fit_alloc_basic
proc; opt_clean
logger -expect log "gather-rooted.en=" 1
opt_first_fit_alloc
logger -check-expected
design -reset
log -pop

# ---------------------------------------------------------------------------
# Entry-side compaction + FF-Q hold (materialised static enable)
# ---------------------------------------------------------------------------
log -header "Entry-side compaction: self-equivalence"
log -push
design -reset
verific -sv opt_first_fit_alloc_compact.sv
verific -import opt_first_fit_alloc_compact
proc; opt_clean
equiv_opt -assert opt_first_fit_alloc
design -reset
log -pop

log -header "Entry-side compaction: rewrite fired (compacted path)"
log -push
design -reset
verific -sv opt_first_fit_alloc_compact.sv
verific -import opt_first_fit_alloc_compact
proc; opt_clean
logger -expect log "gather-rooted-compacted" 1
opt_first_fit_alloc
logger -check-expected
design -reset
log -pop

# -max-therm 0 forces both the lane- and entry-side prefix scans onto the
# saturating binary count fallback (instead of the thermometer), which is the
# path taken when nb > max_therm_nb. Must still rewrite and stay equivalent.
log -header "Entry-side compaction: binary prefix fallback (-max-therm 0)"
log -push
design -reset
verific -sv opt_first_fit_alloc_compact.sv
verific -import opt_first_fit_alloc_compact
proc; opt_clean
equiv_opt -assert opt_first_fit_alloc -max-therm 0
design -reset
log -pop

log -header "Entry-side compaction: binary prefix fallback rewrite fired"
log -push
design -reset
verific -sv opt_first_fit_alloc_compact.sv
verific -import opt_first_fit_alloc_compact
proc; opt_clean
logger -expect log "gather-rooted-compacted" 1
opt_first_fit_alloc -max-therm 0
logger -check-expected
design -reset
log -pop

# ---------------------------------------------------------------------------
# Composite negated enable (!lhit & req_vld) + stride-2 data + compaction
# (track_texel-shaped, lhit exposed as a port)
# ---------------------------------------------------------------------------
log -header "Strided composite enable: self-equivalence"
log -push
design -reset
verific -sv opt_first_fit_alloc_strided.sv
verific -import opt_first_fit_alloc_strided
proc; opt_clean
equiv_opt -assert opt_first_fit_alloc
design -reset
log -pop

log -header "Strided composite enable: rewrite fired (compacted path)"
log -push
design -reset
verific -sv opt_first_fit_alloc_strided.sv
verific -import opt_first_fit_alloc_strided
proc; opt_clean
logger -expect log "gather-rooted-compacted" 1
opt_first_fit_alloc
logger -check-expected
design -reset
log -pop

