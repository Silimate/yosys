# ---------------------------------------------------------------------------
log -header "FSM/hit guard peeling: self-equivalence"
log -push
design -reset
verific -sv opt_first_fit_alloc_fsm.sv
verific -import opt_first_fit_alloc_fsm
proc; opt_clean
equiv_opt -assert opt_first_fit_alloc
design -reset
log -pop

log -header "FSM/hit guard peeling: rewrite fired (compacted path)"
log -push
design -reset
verific -sv opt_first_fit_alloc_fsm.sv
verific -import opt_first_fit_alloc_fsm
proc; opt_clean
logger -expect log "gather-rooted-compacted" 1
opt_first_fit_alloc
logger -check-expected
design -reset
log -pop

# ---------------------------------------------------------------------------
# Scaling stress (N=32 lanes -> NB=4 slots, compacted path): must rewrite and
# stay within budget (no pathological blowup).
# ---------------------------------------------------------------------------
log -header "Scaling N=32: self-equivalence"
log -push
design -reset
verific -sv opt_first_fit_alloc_scale.sv
verific -import opt_first_fit_alloc_scale32
proc; opt_clean
equiv_opt -assert opt_first_fit_alloc
design -reset
log -pop

log -header "Scaling N=32: rewrite fired within budget"
log -push
design -reset
verific -sv opt_first_fit_alloc_scale.sv
verific -import opt_first_fit_alloc_scale32
proc; opt_clean
logger -expect log "gather-rooted-compacted" 1
opt_first_fit_alloc
logger -check-expected
design -reset
log -pop

# ---------------------------------------------------------------------------
# dsel-rooted regression: the original split-root path must keep firing (its
# own log line, NOT a gather-rooted one), so the gather-root anchor does not
# steal or double-claim dsel-shaped designs.
# ---------------------------------------------------------------------------
log -header "dsel-rooted: self-equivalence"
log -push
design -reset
verific -sv opt_first_fit_alloc_dsel.sv
verific -import opt_first_fit_alloc_dsel
proc; opt_clean
equiv_opt -assert opt_first_fit_alloc
design -reset
log -pop

log -header "dsel-rooted: original split-root path fires"
log -push
design -reset
verific -sv opt_first_fit_alloc_dsel.sv
verific -import opt_first_fit_alloc_dsel
proc; opt_clean
logger -expect log "first_fit_alloc.en=.en, exclusive" 1
opt_first_fit_alloc
logger -check-expected
design -reset
log -pop

# ---------------------------------------------------------------------------
# Yosys read_verilog -sv frontend variant (packed flat ports): the gather-root
# anchor must fire on the yosys lowering (memory -> registers) too.
# ---------------------------------------------------------------------------
log -header "Yosys frontend: self-equivalence"
log -push
design -reset
read_verilog -sv opt_first_fit_alloc_frontend.v
hierarchy -top opt_first_fit_alloc_yosys_basic
proc; opt_clean
equiv_opt -assert opt_first_fit_alloc
design -reset
log -pop

log -header "Yosys frontend: rewrite fired (clean gather-root path)"
log -push
design -reset
read_verilog -sv opt_first_fit_alloc_frontend.v
hierarchy -top opt_first_fit_alloc_yosys_basic
proc; opt_clean
logger -expect log "gather-rooted.en=" 1
opt_first_fit_alloc
logger -check-expected
design -reset
log -pop

# ---------------------------------------------------------------------------
# Near-miss negatives: structurally gather-like but NOT a first-fit, so the
# ConstEval fingerprint must reject them (no region rewritten).
# ---------------------------------------------------------------------------
log -header "Negative: diagonal masked read (reads own lane, not j-th enabled)"
log -push
design -reset
verific -sv opt_first_fit_alloc_negative.sv
verific -import opt_first_fit_alloc_diag
proc; opt_clean
logger -expect log "Rewrote 0 first-fit alloc" 1
opt_first_fit_alloc
logger -check-expected
design -reset
log -pop

log -header "Negative: non-exclusive draw (no lpick chaining -> not first-fit)"
log -push
design -reset
verific -sv opt_first_fit_alloc_negative.sv
verific -import opt_first_fit_alloc_noexcl
proc; opt_clean
logger -expect log "Rewrote 0 first-fit alloc" 1
opt_first_fit_alloc
logger -check-expected
design -reset
log -pop
